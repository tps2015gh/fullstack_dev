#--------------------------------------------------------------------
# MySQL Environment Configuration Template
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

# Default database configuration
database.default.DBDriver = MySQLi
database.default.hostname = localhost
database.default.database = tps2015gh_issue_tracker
database.default.username = root
database.default.password =
database.default.DBPrefix =
database.default.port     = 3306
database.default.DBDebug  = true

# Alternative: Central Issue Tracker database
# database.default.database = central_issue_tracker

# Alternative: Win Audit database
# database.default.database = win_audit

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080/'
app.forceGlobalSecureRequests = false

#--------------------------------------------------------------------
# CLI Database Manager
#--------------------------------------------------------------------
# Use the interactive CLI menu to manage databases:
#   php spark db:manager
#
# Features:
#   - Check database existence
#   - List all databases
#   - Create database (tps2015gh_issue_tracker)
#   - Initialize database with migrations
#   - Export database to SQL
#   - Import database from SQL
#   - List export files
#   - Test MySQL connection
#   - Switch database configuration
